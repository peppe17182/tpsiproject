RewriteEngine On

# ---------------------------------------------------------------
# Sicurezza: nascondere l'implementazione all'esterno.
# Blocca l'accesso diretto a TUTTI i file PHP (solo richieste
# esterne; le riscritture interne hanno REDIRECT_STATUS valorizzato).
# Blocca anche l'accesso ai file sensibili (.ini, .sql).
# ---------------------------------------------------------------
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule \.(php|ini|sql)$ - [F,L]

RewriteRule ^general(/|$) - [F,L]
RewriteRule ^specific(/|$) - [F,L]

# ---------------------------------------------------------------
# Routing: tutte le richieste che non corrispondono a file o
# directory fisiche vengono instradate verso index.php.
# Il percorso originale viene passato nel parametro GET 'url'.
# ---------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
